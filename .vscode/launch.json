{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run MDR Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/tools/mdr-vscode",
        "${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/tools/mdr-vscode/**/*.js"
      ]
    }
  ]
}
