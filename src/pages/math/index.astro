---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { mathEdges, mathSections } from "../../data/mathIndex";

const mermaidGraph = ["graph TB", ...mathSections.flatMap((section) => section.pages.flatMap((page) => [`${page.id}[${page.title}]`, `click ${page.id} href "${page.href}"`])), ...mathEdges.map(([from, to]) => `${from} --> ${to}`)].join("\n");
---

<BaseLayout title="数学" breadcrumbs={[{ href: "/index.html", label: "ホーム" }]}>
  <details>
    <summary>各ページの関係</summary>
    <div class="mermaid panzoom">{mermaidGraph}</div>
  </details>
  <h2>数理論理学</h2>
  <p>数理論理学はメタ数学(数学それ自身)に対して研究する分野である．</p>
  <h3>数学の入門</h3>
  <p>数学を勉強するにあたって，知っておきたい基礎的な知識を紹介する．入門に最低限な知識のみを紹介しているため，形式化や詳しい用語を省略している部分もある．</p>
  <ul>
    {
      mathSections
        .find((section) => section.headingId === "introduction-to-mathematics")
        ?.pages.map((page) => (
          <li>
            <a href={page.href}>{page.title}</a>
          </li>
        ))
    }
  </ul>
  <h3>数学基礎論</h3>
  <h3>モデル理論</h3>
  <ul>
    <li>命題論理</li>
    <li>述語論理</li>
    <li>高階述語論理</li>
    <li>様相論理</li>
  </ul>
  <h3>証明論</h3>
  <ul>
    <li>ヒルベルト流</li>
    <li>シークエント計算</li>
    <li>ゲンチェン流</li>
  </ul>
  <h3>理論計算機科学</h3>
  <ul>
    <li>言語</li>
    <li>オートマトン</li>
    <li>チューリングマシン</li>
    <li>不完全性定理</li>
    <li>$lambda$計算</li>
    <li>型付き$lambda$計算</li>
  </ul>

  <h2>代数学</h2>

  <h2>解析学</h2>

  <h2>幾何学</h2>

  <h2>統計学</h2>

  <h2>数理最適化</h2>

  <h2>離散数学</h2>

  <h2>数値計算</h2>
</BaseLayout>
