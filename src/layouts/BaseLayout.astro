---
import { decodeNamedCharacterReference } from "decode-named-character-reference";
import { typst2tex } from "tex2typst";
import chatToggleScriptUrl from "../scripts/chat-toggle.ts?url";
import lazyIframeScriptUrl from "../scripts/lazy-iframe.ts?url";
import mermaidScriptUrl from "../scripts/mermaid.ts?url";
import panzoomScriptUrl from "../scripts/panzoom.ts?url";

interface Breadcrumb {
  href: string;
  label: string;
}

interface ScriptAsset {
  src: string;
}

interface Props {
  title?: string;
  breadcrumbs?: Breadcrumb[];
  extraScripts?: ScriptAsset[];
  frontmatter?: {
    title?: string;
    breadcrumbs?: Breadcrumb[];
    extraScripts?: ScriptAsset[];
  };
}

const frontmatter = Astro.props.frontmatter ?? {};
const title = Astro.props.title ?? frontmatter.title ?? "";
const breadcrumbs = Astro.props.breadcrumbs ?? frontmatter.breadcrumbs ?? [];
const extraScripts = Astro.props.extraScripts ?? frontmatter.extraScripts ?? [];

// `base` とページ階層を考慮して、内部リンクを現在ページからの相対パスにする。
const normalizeSegments = (value: string) =>
  value.split("/").filter(Boolean);

const relativePath = (fromDir: string, toPath: string) => {
  const fromParts = normalizeSegments(fromDir);
  const toParts = normalizeSegments(toPath);

  while (fromParts.length > 0 && toParts.length > 0 && fromParts[0] === toParts[0]) {
    fromParts.shift();
    toParts.shift();
  }

  const upward = fromParts.map(() => "..");
  const result = [...upward, ...toParts].join("/");
  return result === "" ? "." : result;
};

const withBase = (target: string) => {
  if (/^[a-z][a-z0-9+.-]*:/i.test(target) || target.startsWith("//") || target.startsWith("#")) {
    return target;
  }

  const base = import.meta.env.BASE_URL.replace(/\/$/, "");
  const currentPath = Astro.url.pathname.replace(/\/$/, "");
  const currentDir = currentPath.includes("/")
    ? currentPath.slice(0, currentPath.lastIndexOf("/")) || "/"
    : "/";
  const normalized = target.startsWith("/") ? target : `/${target}`;
  const absoluteTarget = `${base}${normalized}`;
  const relativeTarget = relativePath(currentDir, absoluteTarget);

  if (relativeTarget.startsWith(".")) return relativeTarget;
  return `./${relativeTarget}`;
};

// 以降の本文変換は、slot をレンダリングした HTML 文字列に対して行う。
const rawContent = await Astro.slots.render("default");

const decodeTextEntityReferences = (value: string) =>
  value.replace(/&(#x[0-9a-fA-F]+|#\d+|[0-9a-zA-Z]+);/g, (match, entity: string) => {
    const decoded = decodeNamedCharacterReference(entity);
    return decoded === false ? match : decoded;
  });

// `$...$` を Typst 風の簡易記法として扱い、MathJax 用の TeX に変換する。
const convertMathDelimiters = (html: string) =>
  html.replace(/\$(.+?)\$/gs, (_match, inner: string) => {
    const bothEdgesSpace = /^\s.*\s$/.test(inner);
    const converted = typst2tex(inner.trim(), { blockMathMode: bothEdgesSpace });
    return bothEdgesSpace ? `\\[${converted}\\]` : `\\(${converted}\\)`;
  });

const stripTags = (value: string) =>
  decodeTextEntityReferences(value.replace(/<[^>]+>/g, "")).trim();

type NavItem = {
  href: string;
  label: string;
  level: number;
  children: NavItem[];
};

type TermItem = {
  href: string;
  label: string;
};

type ContentTransform<T> = {
  html: string;
  items: T[];
};

// h2/h3 に id を補い、目次用の一覧を作る。
const addHeadingIds = (html: string): ContentTransform<NavItem> => {
  const items: NavItem[] = [];
  let headingId = 0;

  const nextHtml = html.replace(
    /<h([23])([^>]*)>([\s\S]*?)<\/h\1>/g,
    (_match, levelText: string, attrs: string, inner: string) => {
      const existingId = attrs.match(/\sid=(["'])(.*?)\1/);
      const id = existingId?.[2] ?? `heading${headingId++}`;
      const nextAttrs = existingId ? attrs : `${attrs} id="${id}"`;

      items.push({
        href: `#${id}`,
        label: stripTags(inner),
        level: Number(levelText),
        children: [],
      });

      return `<h${levelText}${nextAttrs}>${inner}</h${levelText}>`;
    },
  );

  return { html: nextHtml, items };
};

// dfn に id を補い、「定義される用語」用の一覧を作る。
const addTermIds = (html: string): ContentTransform<TermItem> => {
  const items: TermItem[] = [];
  let termId = 0;

  const nextHtml = html.replace(
    /<dfn([^>]*)>([\s\S]*?)<\/dfn>/g,
    (_match, attrs: string, inner: string) => {
      const existingId = attrs.match(/\sid=(["'])(.*?)\1/);
      const id = existingId?.[2] ?? `define${termId++}`;
      const nextAttrs = existingId ? attrs : `${attrs} id="${id}"`;

      items.push({
        href: `#${id}`,
        label: stripTags(inner),
      });

      return `<dfn${nextAttrs}>${inner}</dfn>`;
    },
  );

  return { html: nextHtml, items };
};

// フラットな見出し一覧を、h2 の下に h3 が入る目次ツリーへ変換する。
const buildTocTree = (headings: NavItem[]) => {
  const tocRoot: NavItem[] = [];
  const stack: NavItem[] = [];

  for (const heading of headings) {
    while (stack.length > 0 && stack[stack.length - 1].level >= heading.level) {
      stack.pop();
    }
    const item = { ...heading, children: [] };
    if (stack.length === 0) {
      tocRoot.push(item);
    } else {
      stack[stack.length - 1].children.push(item);
    }
    stack.push(item);
  }

  return tocRoot;
};

// 本文変換の実行順。
const withHeadingIds = addHeadingIds(rawContent);
const withTermIds = addTermIds(withHeadingIds.html);
const contentHtml = convertMathDelimiters(withTermIds.html);
const headings = withHeadingIds.items;
const terms = withTermIds.items;
const tocRoot = buildTocTree(headings);

// 本文に必要なものだけ、ページ単位で追加スクリプトを読み込む。
const hasChat = /class=(["']).*?\b(?:you|me)\b.*?\1/.test(contentHtml);
const hasIframe = /<iframe\b/i.test(contentHtml);
const hasMermaid = /class=(["']).*?\bmermaid\b.*?\1/.test(contentHtml);
const hasPanzoom = /class=(["']).*?\bpanzoom\b.*?\1/.test(contentHtml);
const hasMath = /\$[\s\S]+?\$/.test(rawContent);
const hasCodeBlock = /<pre\b[^>]*class=(["'])[^"']*\bastro-code\b/.test(contentHtml);

const pageTitle = `学問の鎖｜${title}`;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/png" href={withBase("/favicon/icon.png")} />
    <link rel="stylesheet" href={withBase("/css/main.css")} />
    {extraScripts.map((script) => <script type="module" src={withBase(script.src)}></script>)}
    {hasMermaid && <script type="module" src={withBase(mermaidScriptUrl)}></script>}
    {hasPanzoom && <script type="module" src={withBase(panzoomScriptUrl)}></script>}
    {hasMath && (
      <script is:inline>
        window.MathJax = {
          loader: {
            load: ["[tex]/physics", "[XyJax]/xypic.js", "[tex]/bussproofs"],
            paths: { XyJax: "https://cdn.jsdelivr.net/gh/sonoisa/XyJax-v3@3.0.1/build/" }
          },
          startup: {
            typeset: false,
            pageReady: () => MathJax.startup.defaultPageReady().then(() => MathJax.typesetPromise())
          },
          tex: {
            tags: "ams",
            packages: {
              "[+]": ["physics", "xypic", "bussproofs"]
            },
            macros: {
              abs: ["\\left|#1\\right|", 1],
              coloneq: [":="],
              entail: ["\\vDash"],
              prove: ["\\vdash"],
              xor: ["\\veebar"]
            }
          },
          chtml: {
            scale: 1,
            mtextInheritFont: true
          }
        };
      </script>
    )}
    {hasMath && <script async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>}
    {hasIframe && <script type="module" src={withBase(lazyIframeScriptUrl)}></script>}
    {hasChat && <script type="module" src={withBase(chatToggleScriptUrl)}></script>}
  </head>
  <body>
    <header>
      <img src={withBase("/favicon/title.svg")} alt="学問の鎖のロゴ" id="logo" />
      <h1>{title}</h1>
      {breadcrumbs.length > 0 && (
        <nav aria-label="パンくず">
          {breadcrumbs.map((crumb) => (
            <>
              <a href={withBase(crumb.href)}>{crumb.label}</a>{" / "}
            </>
          ))}
        </nav>
      )}
      {tocRoot.length > 0 && (
        <details>
          <summary>目次</summary>
          <ul>
            {tocRoot.map(function renderItem(item) {
              return (
                <li>
                  <a href={item.href} class="tocLink">{item.label}</a>
                  {item.children.length > 0 && <ul>{item.children.map(renderItem)}</ul>}
                </li>
              );
            })}
          </ul>
        </details>
      )}
      {terms.length > 0 && (
        <details>
          <summary>定義される用語</summary>
          {terms.map((term, index) => (
            <>
              {index > 0 && "，"}
              <a href={term.href} class="tocLink">{term.label}</a>
            </>
          ))}
        </details>
      )}
      {hasChat && (
        <details>
          <summary>設定</summary>
          <label>
            <input type="checkbox" data-chat-toggle checked />
            会話を表示
          </label>
        </details>
      )}
    </header>
    <main>
      <Fragment set:html={contentHtml} />
    </main>
    <footer>Copyright © raygo All Rights Reserved since 2016.</footer>
    {hasCodeBlock && (
      <script is:inline>
        document.querySelectorAll("pre.astro-code").forEach((codeBlock) => {
          const wrapper = document.createElement("div");
          wrapper.className = "code-block-wrapper";
          codeBlock.parentNode?.insertBefore(wrapper, codeBlock);
          wrapper.appendChild(codeBlock);

          const button = document.createElement("button");
          button.type = "button";
          button.className = "code-copy-button";
          button.innerHTML = `
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <rect x="8" y="8" width="10" height="12" rx="1.5"></rect>
              <rect x="5" y="4" width="10" height="12" rx="1.5"></rect>
            </svg>
          `;
          button.setAttribute("aria-label", "コードをコピー");

          button.addEventListener("click", async () => {
            const code = codeBlock.textContent ?? "";

            try {
              await navigator.clipboard.writeText(code);
              button.classList.add("is-copied");
              button.setAttribute("aria-label", "コピーしました");
            } catch {
              button.classList.add("is-failed");
              button.setAttribute("aria-label", "コピーに失敗しました");
            }

            window.setTimeout(() => {
              button.classList.remove("is-copied", "is-failed");
              button.setAttribute("aria-label", "コードをコピー");
            }, 1400);
          });

          wrapper.appendChild(button);
        });
      </script>
    )}
  </body>
</html>
